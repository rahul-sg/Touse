# Copy to .env and fill in values
# Never commit the real .env file

# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=change-me-strong-password

# ── External API keys ─────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1...
FRED_API_KEY=your_fred_key         # https://fred.stlouisfed.org/docs/api/api_key.html
BLS_API_KEY=your_bls_key           # https://data.bls.gov/registrationEngine/
BEA_API_KEY=your_bea_key           # https://apps.bea.gov/API/signup/
CENSUS_API_KEY=your_census_key     # https://api.census.gov/data/key_signup.html
RAPIDAPI_KEY=your_rapidapi_key     # for live listings (optional — falls back to mock)

# ── Observability ─────────────────────────────────────────────
SENTRY_DSN=                        # leave blank to disable
